@model NewsApp.Models.News
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Delete News"].Value;

    string title =
        System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("bn")
        ? (Model.TitleBangla ?? Model.TitleEnglish)
        : (Model.TitleEnglish ?? Model.TitleBangla);

    string description =
        System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("bn")
        ? (Model.DescriptionBangla ?? Model.DescriptionEnglish)
        : (Model.DescriptionEnglish ?? Model.DescriptionBangla);

    string GetYoutubeId(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return "";

        try
        {
            Uri uri = new Uri(url);

            // youtu.be/xxxx
            if (uri.Host.Contains("youtu.be"))
                return uri.AbsolutePath.Trim('/');

            // youtube.com/watch?v=xxxx
            if (uri.Query.Contains("v="))
            {
                var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

                if (query.ContainsKey("v"))
                    return query["v"].ToString();
            }

            // youtube.com/embed/xxxx
            if (url.Contains("embed/"))
                return url.Split("embed/").Last().Split('?')[0];

            // youtube shorts
            if (url.Contains("shorts/"))
                return url.Split("shorts/").Last().Split('?')[0];

            return "";
        }
        catch
        {
            return "";
        }
    }
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

<style>

    body {
        background: #f4f6fb;
        font-family: "Segoe UI", sans-serif;
    }

    .delete-wrapper {
        max-width: 950px;
        margin: auto;
    }

    .warning-box {
        background: linear-gradient(135deg, #dc3545, #a71d2a);
        color: white;
        border-radius: 18px;
        padding: 18px 22px;
        margin-bottom: 25px;
        box-shadow: 0 10px 25px rgba(220,53,69,0.25);
    }

    .delete-card {
        background: white;
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 12px 35px rgba(0,0,0,0.08);
    }

    .media-box {
        width: 100%;
        height: 420px;
        background: #0f0f0f;
        overflow: hidden;
        position: relative;
    }

        .media-box img,
        .media-box video,
        .media-box iframe {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border: none;
        }

    .empty-media {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        color: #aaa;
        font-size: 15px;
    }

    .content-box {
        padding: 30px;
    }

    .news-title {
        font-size: 34px;
        font-weight: 800;
        color: #111;
        line-height: 1.4;
        margin-bottom: 15px;
    }

    .meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 25px;
    }

    .meta-badge {
        background: #f1f3f5;
        padding: 8px 14px;
        border-radius: 50px;
        font-size: 14px;
        color: #444;
        font-weight: 600;
    }

    .badge-breaking {
        background: #dc3545;
        color: white;
    }

    .badge-featured {
        background: #ffc107;
        color: #111;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        color: #111;
        margin-bottom: 12px;
    }

    .description-box {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 20px;
        line-height: 1.9;
        color: #444;
        font-size: 15px;
        white-space: pre-line;
    }

    .danger-note {
        background: #fff3cd;
        color: #856404;
        padding: 14px 18px;
        border-radius: 14px;
        margin-top: 25px;
        font-size: 14px;
        border: 1px solid #ffe69c;
    }

    .action-box {
        margin-top: 30px;
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .btn-rounded {
        border-radius: 50px;
        padding: 10px 24px;
        font-weight: 600;
    }

    @@media(max-width:768px) {

        .media-box {
            height: 250px;
        }

        .content-box {
            padding: 20px;
        }

        .news-title {
            font-size: 24px;
        }
    }

</style>

<div class="container py-4">

    <div class="delete-wrapper">

        <!-- WARNING -->

        <div class="warning-box d-flex align-items-center gap-3">

            <i class="bi bi-exclamation-triangle-fill fs-3"></i>

            <div>
                <h5 class="mb-1">
                    @Localizer["Delete Warning"].Value
                </h5>

                <small>
                    @Localizer["This action cannot be undone"].Value
                </small>
            </div>

        </div>

        <!-- CARD -->

        <div class="delete-card">

            <!-- MEDIA -->

            <div class="media-box">

                @if (!string.IsNullOrWhiteSpace(Model.VideoPath))
                {
                    <video controls autoplay muted>

                        <source src="@Url.Content("~/assets/video/" + Model.VideoPath)"
                                type="video/mp4" />

                    </video>
                }
                else if (!string.IsNullOrWhiteSpace(Model.VideoUrl))
                {
                    var videoId = GetYoutubeId(Model.VideoUrl);

                    if (!string.IsNullOrWhiteSpace(videoId))
                    {
                        <iframe src="https://www.youtube.com/embed/@videoId"
                                allowfullscreen>
                        </iframe>
                    }
                    else
                    {
                        <div class="empty-media">

                            <i class="bi bi-camera-video-off fs-1"></i>

                            <div class="mt-2">
                                @Localizer["Invalid Video"].Value
                            </div>

                        </div>
                    }
                }
                else if (!string.IsNullOrWhiteSpace(Model.Image))
                {
                    <img src="@Url.Content("~/assets/img/" + Model.Image)"
                         alt="@title" />
                }
                else
                {
                    <div class="empty-media">

                        <i class="bi bi-image fs-1"></i>

                        <div class="mt-2">
                            @Localizer["No Media Available"].Value
                        </div>

                    </div>
                }

            </div>

            <!-- CONTENT -->

            <div class="content-box">

                <h1 class="news-title">
                    @title
                </h1>

                <!-- META -->

                <div class="meta-row">

                    <span class="meta-badge">

                        <i class="bi bi-calendar-event"></i>

                        @Model.Date.ToString("dd MMM yyyy")

                    </span>

                    <span class="meta-badge">

                        <i class="bi bi-folder"></i>

                        @(Model.Category?.NameEnglish ?? Localizer["Uncategorized"].Value)

                    </span>

                    @if (Model.IsBreaking)
                    {
                        <span class="meta-badge badge-breaking">

                            🔴 @Localizer["Breaking"].Value

                        </span>
                    }

                    @if (Model.IsFeatured)
                    {
                        <span class="meta-badge badge-featured">

                            ⭐ @Localizer["Featured"].Value

                        </span>
                    }

                </div>

                <!-- DESCRIPTION -->

                <div class="section-title">

                    @Localizer["News Description"].Value

                </div>

                <div class="description-box">

                    @(string.IsNullOrWhiteSpace(description)
                                        ? Localizer["No Description Available"].Value
                                        : description)

                </div>

                <!-- WARNING -->

                <div class="danger-note">

                    <i class="bi bi-exclamation-circle-fill"></i>

                    @Localizer["Deleting this news will permanently remove all related data and media files"].Value

                </div>

                <!-- ACTIONS -->

                <form asp-action="Delete" method="post">

                    <input type="hidden" asp-for="Id" />

                    <div class="action-box">

                        <button type="submit"
                                class="btn btn-danger btn-rounded">

                            <i class="bi bi-trash3-fill"></i>

                            @Localizer["Yes Delete"].Value

                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary btn-rounded">

                            <i class="bi bi-arrow-left"></i>

                            @Localizer["Cancel"].Value

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>