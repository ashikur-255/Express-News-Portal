@model NewsApp.Models.News

@using NewsApp.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Edit News";

    string GetYouTubeId(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return "";

        try
        {
            Uri uri = new Uri(url);

            // youtu.be/xxxx
            if (uri.Host.Contains("youtu.be"))
                return uri.AbsolutePath.Trim('/');

            // youtube.com/watch?v=xxxx
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

            if (query.ContainsKey("v"))
                return query["v"].ToString();

            // youtube.com/embed/xxxx
            if (url.Contains("embed/"))
                return url.Split("embed/").Last().Split('?')[0];

            // youtube shorts
            if (url.Contains("shorts/"))
                return url.Split("shorts/").Last().Split('?')[0];
        }
        catch
        {
            return "";
        }

        return "";
    }

    var youtubeId = GetYouTubeId(Model.VideoUrl);
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

<style>

    body {
        background: #f4f6fb;
        font-family: "Segoe UI", sans-serif;
    }

    .page-header {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        padding: 20px 24px;
        border-radius: 18px;
        margin-bottom: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.10);
    }

    .edit-card {
        background: #fff;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 18px;
        color: #111;
    }

    .form-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        min-height: 48px;
        border: 1px solid #dce1e7;
        padding: 12px 14px;
    }

    textarea.form-control {
        min-height: 150px;
        resize: vertical;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.2rem rgba(13,110,253,.15);
    }

    .media-box {
        width: 100%;
        height: 260px;
        background: #111;
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 15px;
    }

        .media-box img,
        .media-box video,
        .media-box iframe {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border: none;
        }

    .empty-box {
        width: 100%;
        height: 260px;
        border-radius: 16px;
        border: 2px dashed #ced4da;
        background: #f8f9fa;
        color: #777;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin-bottom: 15px;
    }

        .empty-box i {
            font-size: 42px;
            margin-bottom: 10px;
        }

    .preview-box {
        width: 100%;
        height: 220px;
        border-radius: 14px;
        overflow: hidden;
        background: #111;
        margin-top: 12px;
        display: none;
    }

        .preview-box img,
        .preview-box video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .switch-box {
        background: #f8f9fa;
        border: 1px solid #ececec;
        padding: 14px 16px;
        border-radius: 14px;
        margin-bottom: 12px;
    }

    .btn-custom {
        border-radius: 50px;
        padding: 10px 24px;
        font-weight: 600;
    }

    .text-danger {
        font-size: 14px;
    }

    @@media(max-width:768px) {

        .edit-card {
            padding: 20px;
        }

        .media-box,
        .empty-box {
            height: 220px;
        }
    }

</style>

<div class="container py-4">

    <!-- PAGE HEADER -->

    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">

        <div>
            <h3 class="mb-1">
                <i class="bi bi-pencil-square"></i>
                Edit News
            </h3>

            <small class="opacity-75">
                Update news article information
            </small>
        </div>

        <a asp-action="Index"
           class="btn btn-light btn-custom">

            <i class="bi bi-arrow-left"></i>
            Back

        </a>

    </div>

    <!-- FORM CARD -->

    <div class="edit-card">

        <form asp-action="Edit"
              enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger">
            </div>

            <div class="row g-4">

                <!-- LEFT SIDE -->

                <div class="col-lg-8">

                    <div class="section-title">
                        News Content
                    </div>

                    <!-- ENGLISH TITLE -->

                    <div class="mb-4">

                        <label asp-for="TitleEnglish"
                               class="form-label">
                        </label>

                        <input asp-for="TitleEnglish"
                               class="form-control"
                               placeholder="Enter English title..." />

                        <span asp-validation-for="TitleEnglish"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- ENGLISH DESCRIPTION -->

                    <div class="mb-4">

                        <label asp-for="DescriptionEnglish"
                               class="form-label">
                        </label>

                        <textarea asp-for="DescriptionEnglish"
                                  rows="6"
                                  class="form-control"
                                  placeholder="Write English news description..."></textarea>

                        <span asp-validation-for="DescriptionEnglish"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- BANGLA TITLE -->

                    <div class="mb-4">

                        <label asp-for="TitleBangla"
                               class="form-label">
                        </label>

                        <input asp-for="TitleBangla"
                               class="form-control"
                               placeholder="বাংলা শিরোনাম লিখুন..." />

                        <span asp-validation-for="TitleBangla"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- BANGLA DESCRIPTION -->

                    <div class="mb-4">

                        <label asp-for="DescriptionBangla"
                               class="form-label">
                        </label>

                        <textarea asp-for="DescriptionBangla"
                                  rows="6"
                                  class="form-control"
                                  placeholder="বাংলা নিউজ বিস্তারিত লিখুন..."></textarea>

                        <span asp-validation-for="DescriptionBangla"
                              class="text-danger">
                        </span>

                    </div>

                </div>

                <!-- RIGHT SIDE -->

                <div class="col-lg-4">

                    <div class="section-title">
                        Media & Settings
                    </div>

                    <!-- DATE -->

                    <div class="mb-4">

                        <label asp-for="Date"
                               class="form-label">
                        </label>

                        <input asp-for="Date"
                               type="date"
                               class="form-control"
                               value="@Model.Date.ToString("yyyy-MM-dd")" />

                        <span asp-validation-for="Date"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- CATEGORY -->

                    <div class="mb-4">

                        <label asp-for="CategoryId"
                               class="form-label">
                        </label>

                        <select asp-for="CategoryId"
                                class="form-select"
                                asp-items="ViewBag.CategoryId">

                            <option value="">
                                -- Select Category --
                            </option>

                        </select>

                        <span asp-validation-for="CategoryId"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- CURRENT MEDIA -->

                    <div class="mb-3">

                        <label class="form-label">
                            Current Media
                        </label>

                        @if (!string.IsNullOrWhiteSpace(Model.VideoPath))
                        {
                            <div class="media-box">

                                <video controls>
                                    <source src="@Url.Content("~/assets/video/" + Model.VideoPath)"
                                            type="video/mp4" />
                                </video>

                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(youtubeId))
                        {
                            <div class="media-box">

                                <iframe src="https://www.youtube.com/embed/@youtubeId"
                                        allowfullscreen>
                                </iframe>

                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(Model.Image))
                        {
                            <div class="media-box">

                                <img src="@Url.Content("~/assets/img/" + Model.Image)"
                                     alt="News Image" />

                            </div>
                        }
                        else
                        {
                            <div class="empty-box">

                                <i class="bi bi-camera-video-off"></i>

                                <span>No media available</span>

                            </div>
                        }

                    </div>

                    <!-- IMAGE -->

                    <div class="mb-4">

                        <label class="form-label">
                            Upload Image
                        </label>

                        <input type="file"
                               name="ImageFile"
                               id="imageInput"
                               class="form-control"
                               accept="image/*" />

                        <div class="preview-box"
                             id="imagePreviewBox">

                            <img id="imagePreview" />

                        </div>

                    </div>

                    <!-- VIDEO -->

                    <div class="mb-4">

                        <label class="form-label">
                            Upload Video
                        </label>

                        <input asp-for="VideoFile"
                               type="file"
                               id="videoInput"
                               class="form-control"
                               accept="video/*" />

                        <div class="preview-box"
                             id="videoPreviewBox">

                            <video id="videoPreview"
                                   controls>
                            </video>

                        </div>

                    </div>

                    <!-- YOUTUBE -->

                    <div class="mb-4">

                        <label asp-for="VideoUrl"
                               class="form-label">
                        </label>

                        <input asp-for="VideoUrl"
                               id="youtubeInput"
                               class="form-control"
                               placeholder="https://youtube.com/watch?v=..." />

                        <small class="text-muted">
                            Use either uploaded video or YouTube URL
                        </small>

                    </div>

                    <!-- FLAGS -->

                    <div class="switch-box">

                        <div class="form-check form-switch">

                            <input asp-for="IsBreaking"
                                   class="form-check-input" />

                            <label asp-for="IsBreaking"
                                   class="form-check-label">
                                🔥 Breaking News
                            </label>

                        </div>

                    </div>

                    <div class="switch-box">

                        <div class="form-check form-switch">

                            <input asp-for="IsFeatured"
                                   class="form-check-input" />

                            <label asp-for="IsFeatured"
                                   class="form-check-label">
                                ⭐ Featured News
                            </label>

                        </div>

                    </div>

                </div>

            </div>

            <!-- BUTTONS -->

            <div class="mt-4 d-flex justify-content-end gap-2">

                <button type="submit"
                        class="btn btn-primary btn-custom">

                    <i class="bi bi-save"></i>
                    Save Changes

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary btn-custom">

                    Cancel

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>

        // =========================
        // IMAGE PREVIEW
        // =========================

        const imageInput = document.getElementById("imageInput");
        const imagePreview = document.getElementById("imagePreview");
        const imagePreviewBox = document.getElementById("imagePreviewBox");

        imageInput?.addEventListener("change", function () {

            const file = this.files?.[0];

            if (!file)
                return;

            const reader = new FileReader();

            reader.onload = function (e) {

                imagePreview.src = e.target.result;
                imagePreviewBox.style.display = "block";

            };

            reader.readAsDataURL(file);

        });

        // =========================
        // VIDEO PREVIEW
        // =========================

        const videoInput = document.getElementById("videoInput");
        const videoPreview = document.getElementById("videoPreview");
        const videoPreviewBox = document.getElementById("videoPreviewBox");
        const youtubeInput = document.getElementById("youtubeInput");

        videoInput?.addEventListener("change", function () {

            const file = this.files?.[0];

            if (!file)
                return;

            videoPreview.src = URL.createObjectURL(file);

            videoPreviewBox.style.display = "block";

            // Clear YouTube URL
            youtubeInput.value = "";

        });

        // =========================
        // YOUTUBE INPUT
        // =========================

        youtubeInput?.addEventListener("input", function () {

            if (this.value.trim() !== "") {

                // Clear uploaded video
                videoInput.value = "";

                videoPreview.src = "";
                videoPreviewBox.style.display = "none";

            }

        });

    </script>

}