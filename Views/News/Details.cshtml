@model NewsApp.Models.News
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["News Details"].Value;

    bool isBangla =
        System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("bn");

    string title =
        isBangla
        ? (Model.TitleBangla ?? Model.TitleEnglish)
        : (Model.TitleEnglish ?? Model.TitleBangla);

    string description =
        isBangla
        ? (Model.DescriptionBangla ?? Model.DescriptionEnglish)
        : (Model.DescriptionEnglish ?? Model.DescriptionBangla);

    string categoryName =
        Model.Category == null
        ? Localizer["Uncategorized"].Value
        : (
            isBangla
            ? (Model.Category.NameBangla ?? Model.Category.NameEnglish )
            : (Model.Category.NameEnglish ?? Model.Category.NameBangla)
          );

    string GetYoutubeId(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return "";

        try
        {
            Uri uri = new Uri(url);

            // youtu.be/xxxx
            if (uri.Host.Contains("youtu.be"))
                return uri.AbsolutePath.Trim('/');

            // youtube.com/watch?v=xxxx
            if (uri.Query.Contains("v="))
            {
                var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

                if (query.ContainsKey("v"))
                    return query["v"].ToString();
            }

            // youtube.com/embed/xxxx
            if (url.Contains("embed/"))
                return url.Split("embed/").Last().Split('?')[0];

            // youtube shorts
            if (url.Contains("shorts/"))
                return url.Split("shorts/").Last().Split('?')[0];

            return "";
        }
        catch
        {
            return "";
        }
    }

    bool hasYoutube = !string.IsNullOrWhiteSpace(Model.VideoUrl);
    bool hasVideoFile = !string.IsNullOrWhiteSpace(Model.VideoPath);
    bool hasImage = !string.IsNullOrWhiteSpace(Model.Image);

    string videoId = GetYoutubeId(Model.VideoUrl);
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

<style>

    body {
        background: #f4f6fb;
        font-family: "Segoe UI", sans-serif;
    }

    .details-wrapper {
        max-width: 1100px;
        margin: auto;
    }

    .news-container {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 12px 35px rgba(0,0,0,0.08);
    }

    /* =========================================
           HERO MEDIA
        ========================================= */

    .hero-media-box {
        width: 100%;
        height: 520px;
        background: #0f0f0f;
        overflow: hidden;
        position: relative;
    }

        .hero-media-box img,
        .hero-media-box video,
        .hero-media-box iframe {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border: none;
        }

    .empty-media {
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
        color: #aaa;
        font-size: 15px;
    }

    /* =========================================
           CONTENT
        ========================================= */

    .news-content-wrapper {
        padding: 35px;
    }

    .top-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

    .meta-badge {
        padding: 8px 14px;
        border-radius: 50px;
        background: #f1f3f5;
        color: #444;
        font-size: 14px;
        font-weight: 600;
    }

    .badge-breaking {
        background: #dc3545;
        color: white;
    }

    .badge-featured {
        background: #ffc107;
        color: #111;
    }

    .news-title {
        font-size: 40px;
        font-weight: 800;
        line-height: 1.4;
        color: #111;
        margin-bottom: 20px;
    }

    .news-meta {
        color: #777;
        font-size: 15px;
        margin-bottom: 25px;
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }

        .news-meta i {
            margin-right: 5px;
        }

    .content-box {
        background: #f8f9fa;
        border-radius: 18px;
        padding: 25px;
        font-size: 17px;
        line-height: 2;
        color: #333;
        white-space: pre-line;
    }

    /* =========================================
           BUTTONS
        ========================================= */

    .action-buttons {
        margin-top: 30px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .btn-rounded {
        border-radius: 50px;
        padding: 10px 24px;
        font-weight: 600;
    }

    /* =========================================
           RESPONSIVE
        ========================================= */

    @@media(max-width:768px) {

        .hero-media-box {
            height: 260px;
        }

        .news-content-wrapper {
            padding: 20px;
        }

        .news-title {
            font-size: 28px;
        }

        .content-box {
            font-size: 15px;
            line-height: 1.8;
        }
    }

</style>

<div class="container py-4">

    <div class="details-wrapper">

        <div class="news-container">

            <!-- =========================================
                 HERO MEDIA
            ========================================= -->

            <div class="hero-media-box">

                @if (hasYoutube && !string.IsNullOrWhiteSpace(videoId))
                {
                    <iframe src="https://www.youtube.com/embed/@videoId"
                            allowfullscreen>
                    </iframe>
                }
                else if (hasVideoFile)
                {
                    <video controls autoplay muted>

                        <source src="@Url.Content("~/assets/video/" + Model.VideoPath)"
                                type="video/mp4" />

                    </video>
                }
                else if (hasImage)
                {
                    <img src="@Url.Content("~/assets/img/" + Model.Image)"
                         alt="@title" />
                }
                else
                {
                    <div class="empty-media">

                        <i class="bi bi-image fs-1"></i>

                        <div class="mt-2">
                            @Localizer["No Media Available"].Value
                        </div>

                    </div>
                }

            </div>

            <!-- =========================================
                 CONTENT
            ========================================= -->

            <div class="news-content-wrapper">

                <!-- CATEGORY + BADGES -->

                <div class="top-meta">

                    <span class="meta-badge">

                        <i class="bi bi-folder"></i>

                        @categoryName

                    </span>

                    @if (Model.IsBreaking)
                    {
                        <span class="meta-badge badge-breaking">

                            🔴 @Localizer["Breaking"].Value

                        </span>
                    }

                    @if (Model.IsFeatured)
                    {
                        <span class="meta-badge badge-featured">

                            ⭐ @Localizer["Featured"].Value

                        </span>
                    }

                </div>

                <!-- TITLE -->

                <h1 class="news-title">

                    @title

                </h1>

                <!-- META -->

                <div class="news-meta">

                    <span>

                        <i class="bi bi-calendar-event"></i>

                        @Model.Date.ToString("dd MMM yyyy")

                    </span>

                    <span>

                        <i class="bi bi-clock"></i>

                        @Model.Date.ToString("hh:mm tt")

                    </span>

                </div>

                <!-- DESCRIPTION -->

                <div class="content-box">

                    @(string.IsNullOrWhiteSpace(description)
                                        ? Localizer["No Description Available"].Value
                                        : description)

                </div>

                <!-- ACTION BUTTONS -->

                <div class="action-buttons">

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-primary btn-rounded">

                            <i class="bi bi-pencil-square"></i>

                            @Localizer["Edit"].Value

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@Model.Id"
                           class="btn btn-danger btn-rounded">

                            <i class="bi bi-trash"></i>

                            @Localizer["Delete"].Value

                        </a>
                    }

                    <a asp-controller="Home"
                       asp-action="Index"
                       class="btn btn-secondary btn-rounded">

                        <i class="bi bi-arrow-left"></i>

                        @Localizer["Back To Home"].Value

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>