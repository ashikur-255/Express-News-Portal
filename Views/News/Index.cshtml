@model IEnumerable<NewsApp.Models.News>

@using NewsApp.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "News Dashboard";

    string GetYouTubeId(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return "";

        try
        {
            Uri uri = new Uri(url);

            // youtu.be/xxxx
            if (uri.Host.Contains("youtu.be"))
                return uri.AbsolutePath.Trim('/');

            // youtube.com/watch?v=xxxx
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

            if (query.ContainsKey("v"))
                return query["v"].ToString();

            // youtube.com/embed/xxxx
            if (url.Contains("embed/"))
                return url.Split("embed/").Last().Split('?')[0];

            // youtube shorts
            if (url.Contains("shorts/"))
                return url.Split("shorts/").Last().Split('?')[0];
        }
        catch
        {
            return "";
        }

        return "";
    }

    string GetYoutubeEmbed(string? url)
    {
        var id = GetYouTubeId(url);

        return !string.IsNullOrWhiteSpace(id)
            ? $"https://www.youtube.com/embed/{id}"
            : "";
    }
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

<style>

    body {
        background: #f4f6fb;
        font-family: "Segoe UI", sans-serif;
    }

    a {
        text-decoration: none;
    }

    .dashboard-header {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        padding: 22px 24px;
        border-radius: 18px;
        margin-bottom: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.10);
    }

        .dashboard-header h2 {
            margin: 0;
            font-weight: 700;
        }

        .dashboard-header small {
            opacity: 0.85;
        }

    .btn-rounded {
        border-radius: 50px;
        padding: 10px 22px;
        font-weight: 600;
    }

    .filter-card {
        background: #fff;
        padding: 18px;
        border-radius: 18px;
        margin-bottom: 25px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    }

    .search-box,
    .form-select {
        border-radius: 12px;
        min-height: 48px;
        border: 1px solid #dce1e7;
    }

        .search-box:focus,
        .form-select:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13,110,253,.15);
        }

    .news-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
        background: #fff;
        transition: 0.35s ease;
        height: 100%;
        cursor: pointer;
        box-shadow: 0 4px 18px rgba(0,0,0,0.06);
    }

        .news-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 14px 35px rgba(0,0,0,0.12);
        }

    .media-box {
        width: 100%;
        height: 230px;
        background: #111;
        overflow: hidden;
        position: relative;
    }

        .media-box img,
        .media-box video,
        .media-box iframe {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border: none;
        }

    .empty-media {
        width: 100%;
        height: 100%;
        color: #bbb;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        font-size: 14px;
    }

        .empty-media i {
            font-size: 36px;
            margin-bottom: 10px;
        }

    .card-body {
        padding: 20px;
    }

    .news-title {
        font-size: 20px;
        font-weight: 700;
        color: #111;
        line-height: 1.5;
        margin-bottom: 10px;
    }

    .news-meta {
        color: #888;
        font-size: 13px;
        margin-bottom: 12px;
    }

    .news-desc {
        color: #666;
        font-size: 14px;
        line-height: 1.7;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .badge-category {
        background: #0d6efd;
        color: white;
        border-radius: 50px;
        padding: 6px 12px;
        font-size: 12px;
    }

    .badge-breaking {
        background: #dc3545;
        color: white;
        border-radius: 50px;
        padding: 6px 12px;
        font-size: 12px;
    }

    .badge-featured {
        background: #ffc107;
        color: #111;
        border-radius: 50px;
        padding: 6px 12px;
        font-size: 12px;
    }

    .action-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .empty-box {
        background: #fff;
        border-radius: 18px;
        padding: 60px 20px;
        text-align: center;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    }

        .empty-box i {
            font-size: 50px;
            color: #999;
            margin-bottom: 12px;
        }

    @@media(max-width:768px) {

        .dashboard-header {
            text-align: center;
        }

            .dashboard-header .btn {
                width: 100%;
            }

        .media-box {
            height: 210px;
        }
    }

</style>

<div class="container py-4">

    <!-- HEADER -->

    <div class="dashboard-header d-flex justify-content-between align-items-center flex-wrap gap-3">

        <div>

            <h2>
                <i class="bi bi-newspaper"></i>
                News Dashboard
            </h2>

            <small>
                Manage all news articles professionally
            </small>

        </div>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create"
               class="btn btn-light btn-rounded">

                <i class="bi bi-plus-circle"></i>
                Create News

            </a>
        }

    </div>

    <!-- FILTER SECTION -->

    <div class="filter-card">

        <div class="row g-3">

            <div class="col-md-7">

                <input type="text"
                       id="searchBox"
                       class="form-control search-box"
                       placeholder="🔍 Search by news title..." />

            </div>

            <div class="col-md-5">

                <select id="categoryFilter"
                        class="form-select">

                    <option value="">
                        All Categories
                    </option>

                    @foreach (var cat in Model
                                        .Where(x => x.Category != null)
                                        .Select(x => x.Category?.NameEnglish)
                                        .Distinct()
                                        .OrderBy(x => x))
                    {
                        <option value="@cat">
                            @cat
                        </option>
                    }

                </select>

            </div>

        </div>

    </div>

    <!-- NEWS GRID -->
    @if (Model != null && Model.Any())
    {
        <div class="row">

            @foreach (var item in Model.OrderByDescending(x => x.Date))
            {
                var categoryName = item.Category?.NameEnglish ?? "Uncategorized";

                var title =
                !string.IsNullOrWhiteSpace(item.TitleEnglish)
                ? item.TitleEnglish
                : item.TitleBangla;

                var description =
                !string.IsNullOrWhiteSpace(item.DescriptionEnglish)
                ? item.DescriptionEnglish
                : item.DescriptionBangla;

                <div class="col-lg-4 col-md-6 mb-4 news-item"
                     data-title="@title"
                     data-category="@categoryName">

                    <div class="card news-card h-100"
                         onclick="window.location.href='@Url.Action("Details", "News", new { id = item.Id })'">

                        <!-- MEDIA -->

                        <div class="media-box">

                            @* VIDEO FILE *@
                            @if (!string.IsNullOrWhiteSpace(item.VideoPath))
                            {
                                <video controls>

                                    <source src="@Url.Content("~/assets/video/" + item.VideoPath)"
                                            type="video/mp4" />

                                </video>
                            }

                            @* YOUTUBE *@
                            else if (!string.IsNullOrWhiteSpace(item.VideoUrl))
                            {
                                var embedUrl = GetYoutubeEmbed(item.VideoUrl);

                                if (!string.IsNullOrWhiteSpace(embedUrl))
                                {
                                    <iframe src="@embedUrl"
                                            allowfullscreen
                                            loading="lazy">
                                    </iframe>
                                }
                            }

                            @* IMAGE *@
                            else if (!string.IsNullOrWhiteSpace(item.Image))
                            {
                                <img src="@Url.Content("~/assets/img/" + item.Image)"
                                     alt="@title" />
                            }

                            @* EMPTY *@
                            else
                            {
                                <div class="empty-media">

                                    <i class="bi bi-camera-video-off"></i>

                                    <span>No Media Available</span>

                                </div>
                            }

                        </div>

                        <!-- BODY -->

                        <div class="card-body d-flex flex-column">

                            <!-- BADGES -->

                            <div class="mb-3 d-flex flex-wrap gap-2">

                                <span class="badge-category">
                                    @categoryName
                                </span>

                                @if (item.IsBreaking)
                                {
                                    <span class="badge-breaking">
                                        🔴 Breaking
                                    </span>
                                }

                                @if (item.IsFeatured)
                                {
                                    <span class="badge-featured">
                                        ⭐ Featured
                                    </span>
                                }

                        </div>

                        <!-- TITLE -->

                        <h5 class="news-title">
                            @title
                        </h5>

                        <!-- META -->

                        <div class="news-meta">

                            <i class="bi bi-calendar-event"></i>

                            @item.Date.ToString("dd MMM yyyy")

                        </div>

                        <!-- DESCRIPTION -->

                        <p class="news-desc flex-grow-1">

                            @(string.IsNullOrWhiteSpace(description)
                                                    ? "No description available"
                                                    : description)

                    </p>

                            <!-- ADMIN ACTIONS -->
                    @if (User.IsInRole("Admin"))
                            {
                                <div class="mt-4 d-flex justify-content-between align-items-center">

                                    <div class="d-flex gap-2">

                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-primary action-btn"
                                           onclick="event.stopPropagation();">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>

                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-info text-white action-btn"
                                           onclick="event.stopPropagation();">

                                            <i class="bi bi-eye"></i>

                                        </a>

                                    </div>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-danger action-btn"
                                       onclick="event.stopPropagation();">

                                        <i class="bi bi-trash"></i>

                                    </a>

                                </div>
                            }

                        </div>

                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <div class="empty-box">

            <i class="bi bi-newspaper"></i>

            <h4 class="fw-bold">
                No News Found
            </h4>

            <p class="text-muted mb-0">
                Start by creating your first news article.
            </p>

        </div>
    }

</div>

@section Scripts {

    <script>

        const searchBox = document.getElementById("searchBox");
        const categoryFilter = document.getElementById("categoryFilter");

        function filterNews() {

            const search =
                searchBox.value.toLowerCase().trim();

            const category =
                categoryFilter.value;

            document.querySelectorAll(".news-item")
                .forEach(item => {

                    const title =
                        (item.dataset.title || "")
                        .toLowerCase();

                    const cat =
                        item.dataset.category || "";

                    const matchSearch =
                        title.includes(search);

                    const matchCategory =
                        category === "" || cat === category;

                    item.style.display =
                        (matchSearch && matchCategory)
                        ? "block"
                        : "none";
                });
        }

        searchBox.addEventListener("keyup", filterNews);

        categoryFilter.addEventListener("change", filterNews);

    </script>

}