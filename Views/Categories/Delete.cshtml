@model NewsApp.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

<style>

    body {
        background: #f4f6fb;
        font-family: "Segoe UI", sans-serif;
    }

    .page-header {
        background: linear-gradient(135deg, #ff416c, #ff4b2b);
        color: white;
        padding: 22px 24px;
        border-radius: 18px;
        margin-bottom: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.10);
    }

    .delete-card {
        background: white;
        border-radius: 18px;
        padding: 30px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        border-left: 6px solid #dc3545;
    }

    .warning-box {
        background: #fff3cd;
        border: 1px solid #ffe69c;
        color: #856404;
        padding: 16px 18px;
        border-radius: 14px;
        margin-bottom: 25px;
        line-height: 1.6;
    }

        .warning-box i {
            margin-right: 8px;
        }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        color: #111;
        margin-bottom: 20px;
    }

    .info-box {
        background: #f8f9fa;
        border: 1px solid #ececec;
        border-radius: 14px;
        padding: 18px;
        margin-bottom: 18px;
    }

    .label {
        font-size: 13px;
        font-weight: 700;
        color: #6c757d;
        text-transform: uppercase;
        margin-bottom: 8px;
        letter-spacing: .5px;
    }

    .value {
        font-size: 18px;
        font-weight: 600;
        color: #111;
        word-break: break-word;
    }

    .danger-value {
        color: #dc3545;
    }

    .btn-custom {
        border-radius: 50px;
        padding: 10px 22px;
        font-weight: 600;
    }

    .danger-note {
        margin-top: 25px;
        padding: 14px 16px;
        border-radius: 12px;
        background: #f8d7da;
        border: 1px solid #f1aeb5;
        color: #842029;
        font-size: 14px;
    }

    @@media(max-width:768px) {

        .delete-card {
            padding: 20px;
        }

        .page-header {
            padding: 18px;
        }

        .value {
            font-size: 16px;
        }
    }

</style>

<div class="container py-4">

    <!-- HEADER -->

    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">

        <div>

            <h3 class="mb-1">
                <i class="bi bi-trash3"></i>
                Delete Category
            </h3>

            <small class="opacity-75">
                This action is permanent and cannot be undone
            </small>

        </div>

        <a asp-action="Index"
           class="btn btn-light btn-custom">

            <i class="bi bi-arrow-left"></i>
            Back

        </a>

    </div>

    <!-- DELETE CARD -->

    <div class="delete-card">

        <!-- WARNING -->

        <div class="warning-box">

            <i class="bi bi-exclamation-triangle-fill"></i>

            <strong>Warning:</strong>

            You are about to permanently delete this category.
            All related news under this category may also be affected.

        </div>

        <div class="section-title">

            Category Information

        </div>

        <!-- ENGLISH NAME -->

        <div class="info-box">

            <div class="label">

                English Name

            </div>

            <div class="value danger-value">

                @(string.IsNullOrWhiteSpace(Model.NameEnglish)
                                ? "No English name"
                                : Model.NameEnglish)

            </div>

        </div>

        <!-- BANGLA NAME -->

        <div class="info-box">

            <div class="label">

                Bangla Name

            </div>

            <div class="value">

                @(string.IsNullOrWhiteSpace(Model.NameBangla)
                                ? "বাংলা নাম নেই"
                                : Model.NameBangla)

            </div>

        </div>

        <!-- TOTAL NEWS -->

        <div class="info-box">

            <div class="label">

                Related News

            </div>

            <div class="value">

                @(Model.News?.Count ?? 0) News Articles

            </div>

        </div>

        <!-- EXTRA WARNING -->

        <div class="danger-note">

            <i class="bi bi-info-circle-fill"></i>

            Deleting this category may break related news references
            if news articles are still assigned to this category.

        </div>

        <!-- FORM -->

        <form asp-action="Delete"
              method="post"
              class="mt-4">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   asp-for="Id" />

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">

                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-custom">

                    Cancel

                </a>

                <button type="submit"
                        class="btn btn-danger btn-custom">

                    <i class="bi bi-trash"></i>
                    Confirm Delete

                </button>

            </div>

        </form>

    </div>

</div>